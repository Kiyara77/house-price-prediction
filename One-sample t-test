import pandas as pd
import numpy as np
from scipy import stats
import xgboost as xgb
from sklearn.model_selection import cross_val_score, KFold
from sklearn.preprocessing import LabelEncoder
from sklearn.metrics import mean_squared_error
import warnings
warnings.filterwarnings('ignore')

train = pd.read_csv('D:\\1\\train.csv')
test = pd.read_csv('D:\\1\\test.csv')
test_ids = test['Id']

#Combine data for unified preprocessing
all_data = pd.concat([train.drop(columns=['SalePrice']), test], axis=0).reset_index(drop=True)

numeric_cols = all_data.select_dtypes(include=[np.number]).columns
for col in numeric_cols:
    all_data[col].fillna(all_data[col].median(), inplace=True)

categorical_cols = all_data.select_dtypes(exclude=[np.number]).columns
for col in categorical_cols:
    all_data[col].fillna('None', inplace=True)

#Apply Label Encoding to categorical variables
label_encoders = {}
for col in categorical_cols:
    le = LabelEncoder()
    all_data[col] = le.fit_transform(all_data[col].astype(str))
    label_encoders[col] = le

#Split back into train and test sets
X_train = all_data.iloc[:len(train)]
X_test = all_data.iloc[len(train):]
y_train = train['SalePrice'].values

xgb_model = xgb.XGBRegressor(
    n_estimators=1000,
    learning_rate=0.05,
    max_depth=6,
    subsample=0.8,
    colsample_bytree=0.8,
    random_state=42
)
xgb_model.fit(X_train, y_train)

#Predict on training set
y_train_pred = xgb_model.predict(X_train)
residuals = y_train - y_train_pred

#Merge residuals and Neighborhood info back into original training set
train_with_residuals = train.copy()
train_with_residuals['residual'] = residuals

#Perform one-sample t-test on residuals for the NridgHt neighborhood
nridg_ht_residuals = train_with_residuals[train_with_residuals['Neighborhood'] == 'NridgHt']['residual'].values

if len(nridg_ht_residuals) > 1:
    t_stat, p_value = stats.ttest_1samp(nridg_ht_residuals, popmean=0)
    mean_resid = np.mean(nridg_ht_residuals)
    std_err = np.std(nridg_ht_residuals, ddof=1) / np.sqrt(len(nridg_ht_residuals))
    
    print("One-sample t-test results for NridgHt neighborhood residuals:")
    print(f"t-statistic: {t_stat:.3f}")
    print(f"p-value: {p_value:.6f}")
    
    print("\nConclusion:")
    if p_value < 0.05:
        print("Reject the null hypothesis at the 5% significance level.")
        print("The model exhibits systematic bias in predicting house prices in this neighborhood.")
    else:
        print("No significant systematic bias detected.")
else:
    print("Insufficient samples in the NridgHt neighborhood to perform a t-test.")
